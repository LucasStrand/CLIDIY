{
  "name": "smask-cli",
  "version": "1.0.0",
  "description": "Ask LLMs questions directly from your terminal",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "smask": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p .",
    "dev": "ts-node --esm src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "llm",
    "gemini",
    "ai",
    "terminal",
    "chatbot"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@inquirer/prompts": "^7.1.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.1",
    "google-auth-library": "^9.14.0",
    "open": "^10.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}





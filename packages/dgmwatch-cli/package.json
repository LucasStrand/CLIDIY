{
  "name": "dgmwatch-cli",
  "version": "0.2.0",
  "description": "Terminal controller for DALCNET DGM watch DMX devices.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dgmwatch": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p .",
    "dev": "ts-node --esm src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "dmx",
    "dalcnet",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.1.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}


